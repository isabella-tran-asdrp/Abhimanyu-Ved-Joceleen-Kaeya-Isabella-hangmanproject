import random


def hangman():
    lives = 6
    words = ["horse","dog","cat","pear","code","music","lizard","snake","mouse","dinosaur","blue","pink","red","orange"]
    answer = ""
    word = random.choice(words)
    print("Let's play hangman!")
    for char in word:
        answer = answer + "_"
    print(answer)
    while lives != 0 and "_" in answer:
        letter = input("Pick a letter (lowercase): ")
        if letter in word:
            index = word.find(letter)
            answer  = answer[:index] + letter + answer[index + 1 :]
            print(answer)
        else:
            lives -= 1
            lives = str(lives)
            print("whoops! you have" , lives ,"lives!")
            lives = int(lives)

    if lives == 0 :
        print("oops you died! try again")
    if "_" not in answer:
        print("good job! lets play again!")
        hangman()
hangman()
